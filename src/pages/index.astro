---
export const prerender = false;

import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import Marquee from "~/components/Marquee.astro";
import ProductGrid from "~/components/ProductGrid.astro";
import Statement from "~/components/Statement.astro";
import BusinessUseCases from "~/components/BusinessUseCases.astro";
import HowToOrder from "~/components/HowToOrder.astro";

import Trust from "~/components/Trust.astro";
import FAQ from "~/components/FAQ.astro";
import FinalCTA from "~/components/FinalCTA.astro";
import Contact from "~/components/Contact.astro";
import StickyWhatsApp from "~/components/StickyWhatsApp.astro";
import ErrorBoundary from "~/components/ErrorBoundary.astro";
import { getProducts, loadFallback } from "~/lib/api";
import type { Product } from "~/lib/api";
import { SITE } from "~/lib/config";

let products: Product[] = [];
let hasProductsError = false;

try {
  products = await getProducts();
} catch (err) {
  console.error("Error fetching products:", err);
  try {
    products = loadFallback();
  } catch (fbErr) {
    console.error("Fallback also failed:", fbErr);
  }
  hasProductsError = products.length === 0;
}

const jsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  url: "https://el-horno-del-pinguino-landing-page.onrender.com",
  logo: "https://el-horno-del-pinguino-landing-page.onrender.com/logo.png",
  description: SITE.description,
  address: { "@type": "PostalAddress", addressLocality: "Loja", addressCountry: "EC" },
};
if (products.length > 0) {
  jsonLd.offers = products.slice(0, 3).map((p) => ({
    "@type": "Offer", name: p.name, description: p.description,
    price: p.price / 100, priceCurrency: p.currency,
    availability: "https://schema.org/InStock",
  }));
}
---
<BaseLayout
  title={`${SITE.name} — Postres artesanales para empresas y ocasiones especiales`}
  description={SITE.description}
  canonicalUrl="https://el-horno-del-pinguino-landing-page.onrender.com"
  jsonLd={jsonLd}
>
  <main>
    <Hero />
    <Marquee />
    <ErrorBoundary hasError={hasProductsError} message="No pudimos cargar los productos ahora. Escríbenos y te contamos lo que tenemos.">
      <ProductGrid products={products} />
    </ErrorBoundary>
    <Statement />
    <BusinessUseCases />
    <HowToOrder />
    <Trust />
    <FAQ />
    <FinalCTA />
    <Contact />
  </main>
  <StickyWhatsApp />
</BaseLayout>
