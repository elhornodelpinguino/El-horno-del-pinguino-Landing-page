---
import { SITE, whatsappLink } from "~/lib/config";
import type { Organization } from "~/lib/api";

interface Props {
  org: Organization | null;
}

const { org } = Astro.props;
const name = org?.name ?? SITE.name;
const description = org?.description ?? SITE.tagline;
---

<header class="animate-on-scroll relative overflow-hidden bg-gradient-to-b from-[#fbebde] via-[#fef3ed] to-white pt-6 pb-24 sm:pb-32">
  <!-- Decorative blobs -->
  <div aria-hidden="true" class="absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full bg-horno-magenta/[0.04] blur-3xl"></div>
  <div aria-hidden="true" class="absolute top-1/3 -right-32 w-[400px] h-[400px] rounded-full bg-horno-orange/[0.06] blur-3xl"></div>
  <div aria-hidden="true" class="absolute -bottom-20 left-1/3 w-80 h-80 rounded-full bg-horno-magenta/[0.03] blur-3xl"></div>

  <nav class="section flex items-center justify-between relative z-10">
    <a href="#" class="flex items-center gap-3 group">
      <img
        src="/isotipo.png"
        alt={`Logo ${name}`}
        class="h-11 w-11 object-contain transition-transform duration-300 group-hover:scale-105"
        loading="eager"
      />
      <span class="font-display text-lg text-horno-magentaDeep hidden sm:inline">{name}</span>
    </a>

    <!-- Desktop nav links — hidden on mobile -->
    <div class="hidden sm:flex gap-6 text-sm font-medium text-horno-magentaDeep/80">
      <a href="#catalogo" class="hover:text-horno-magenta transition">Catálogo</a>
      <a href="#como-pedir" class="hover:text-horno-magenta transition">Cómo pedir</a>
      <a href="#contacto" class="hover:text-horno-magenta transition">Contacto</a>
    </div>

    <!-- Hamburger button — visible on mobile only -->
    <button
      data-hamburger
      aria-controls="mobile-nav"
      class="sm:hidden flex flex-col gap-1.5 p-3 -mr-3 min-w-[44px] min-h-[44px] items-center justify-center focus:outline-none focus:ring-2 focus:ring-horno-magenta focus:ring-offset-2 rounded-lg"
      aria-label="Abrir menú"
      type="button"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <!-- Mobile nav overlay -->
    <div id="mobile-nav" data-mobile-nav>
      <a href="#catalogo" class="min-h-[44px] flex items-center" tabindex="0">Catálogo</a>
      <a href="#como-pedir" class="min-h-[44px] flex items-center" tabindex="0">Cómo pedir</a>
      <a href="#contacto" class="min-h-[44px] flex items-center" tabindex="0">Contacto</a>
    </div>
  </nav>

  <div class="section relative z-10 mt-16 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] items-center">
    <div>
      <span class="eyebrow">🍰 Artesanal · Loja, Ecuador</span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mb-6">
        Postres que <span class="text-horno-magenta">sorprenden</span>,
        <span class="italic">hechos con alma</span>.
      </h1>
      <p class="text-lg text-horno-magentaDeep/80 max-w-xl mb-8 leading-relaxed">
        {description}
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="#catalogo" class="btn-primary">
          Ver catálogo
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </a>
        <a
          href={whatsappLink(`Hola ${name}! Vi su web y quiero más info.`)}
          target="_blank"
          rel="noopener"
          class="btn-secondary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-emerald-600">
            <path d="M.057 24l1.687-6.163A11.867 11.867 0 010 12C0 5.373 5.373 0 12 0c3.181 0 6.167 1.24 8.413 3.488A11.82 11.82 0 0124 12c0 6.627-5.373 12-12 12a11.86 11.86 0 01-5.7-1.452L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981z"/>
          </svg>
          Hablar por WhatsApp
        </a>
      </div>

      <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3 text-sm text-horno-magentaDeep/70">
        <span class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-horno-magenta"></span> Entregas en Loja</span>
        <span class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-horno-magenta"></span> Por pedido</span>
        <span class="flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-horno-magenta"></span> Calidad artesanal</span>
      </div>
    </div>

    <div class="relative">
      <div
        class="aspect-square rounded-[2rem] overflow-hidden shadow-soft ring-1 ring-white/50 relative bg-white flex items-center justify-center"
      >
        <div class="penguin-sprite" aria-hidden="true"></div>
        <!-- Badge -->
        <div class="absolute top-4 right-4 bg-horno-magenta text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-full">Nuevo</div>
      </div>
      <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-card px-4 py-2.5 flex items-center gap-2.5">
        <div class="h-2.5 w-2.5 rounded-full bg-emerald-500 animate-pulse"></div>
        <p class="text-xs font-medium text-horno-magentaDeep">Tomando pedidos hoy</p>
      </div>
    </div>
  </div>
</header>

<script>
  import "~/scripts/mobile-nav.js";
</script>

<div class="ornament-divider" aria-hidden="true"></div>
