---
import { SITE, whatsappLink, instagramLink } from "~/lib/config";
import type { Organization } from "~/lib/api";

interface Props {
  org: Organization | null;
}

const { org } = Astro.props;
const name = org?.name ?? SITE.name;
const orderMessage = `Hola ${name}! Vi su web y quiero hacer un pedido artesanal.`;
const instagramUrl = instagramLink();
---

<header class="hero-shell animate-on-scroll relative overflow-hidden pt-6 pb-20 sm:pb-28">
  <div class="hero-glow hero-glow-left" aria-hidden="true"></div>
  <div class="hero-glow hero-glow-right" aria-hidden="true"></div>
  <div class="ios-bubble hero-bubble hero-bubble-1" aria-hidden="true"></div>
  <div class="ios-bubble hero-bubble hero-bubble-2" aria-hidden="true"></div>
  <div class="ios-bubble hero-bubble hero-bubble-3" aria-hidden="true"></div>

  <nav class="section relative z-20 flex items-center justify-between">
    <a href="#" class="group flex items-center gap-3" aria-label={`${name} - inicio`}>
      <span class="grid h-12 w-12 place-items-center rounded-2xl bg-white/80 shadow-card ring-1 ring-horno-magenta/10 backdrop-blur">
        <img src="/isotipo.png" alt={`Logo ${name}`} class="h-9 w-9 object-contain transition-transform duration-300 group-hover:scale-105" loading="eager" />
      </span>
      <span class="hidden font-display text-lg text-horno-magentaDeep sm:inline">{name}</span>
    </a>

    <div class="hidden items-center gap-7 rounded-full border border-white/70 bg-white/60 px-5 py-3 text-sm font-medium text-horno-magentaDeep/80 shadow-card backdrop-blur sm:flex">
      <a href="#catalogo" class="transition hover:text-horno-magenta">Catálogo</a>
      <a href="#como-pedir" class="transition hover:text-horno-magenta">Cómo pedir</a>
      <a href="#contacto" class="transition hover:text-horno-magenta">Contacto</a>
    </div>

    <a href={whatsappLink(orderMessage)} target="_blank" rel="noopener" class="hidden rounded-full bg-horno-magenta px-5 py-3 text-sm font-semibold text-white shadow-soft transition hover:-translate-y-0.5 hover:bg-horno-magentaDeep md:inline-flex">
      Pedir ahora
    </a>

    <button data-hamburger aria-controls="mobile-nav" class="flex min-h-[44px] min-w-[44px] flex-col items-center justify-center gap-1.5 rounded-lg p-3 -mr-3 focus:outline-none focus:ring-2 focus:ring-horno-magenta focus:ring-offset-2 sm:hidden" aria-label="Abrir menú" type="button">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <div id="mobile-nav" data-mobile-nav>
      <a href="#catalogo" class="flex min-h-[44px] items-center" tabindex="0">Catálogo</a>
      <a href="#como-pedir" class="flex min-h-[44px] items-center" tabindex="0">Cómo pedir</a>
      <a href="#contacto" class="flex min-h-[44px] items-center" tabindex="0">Contacto</a>
    </div>
  </nav>

  <div class="section relative z-10 mt-14 grid items-center gap-12 lg:mt-16 lg:grid-cols-[1.03fr_0.97fr]">
    <div class="max-w-2xl">
      <span class="eyebrow rounded-full bg-white/70 px-4 py-2 shadow-card backdrop-blur">El pingüino chef · Loja</span>
      <h1 class="mt-4 mb-6 text-4xl leading-[1.02] sm:text-5xl lg:text-6xl">
        El postre llega con sabor, empaque y <span class="text-horno-magenta">personaje propio</span>.
      </h1>
      <p class="mb-8 max-w-xl text-lg leading-relaxed text-horno-magentaDeep/80">
        Pedidos artesanales guiados por WhatsApp, con el pingüino como sello visual de la marca.
      </p>

      <div class="hero-actions">
        <div class="hero-actions-main">
          <a href="#catalogo" class="btn-primary">Ver catálogo</a>
          <a href={whatsappLink(orderMessage)} target="_blank" rel="noopener" class="btn-secondary">
            <svg viewBox="0 0 32 32" class="h-6 w-6" aria-hidden="true">
              <circle cx="16" cy="16" r="15" fill="#25D366" />
              <path fill="#fff" d="M16.04 7.15a8.64 8.64 0 0 0-7.38 13.12l-.93 3.43 3.51-.92a8.65 8.65 0 1 0 4.8-15.63Zm0 15.77a7.1 7.1 0 0 1-3.62-.99l-.26-.15-2.08.54.56-2.02-.17-.27a7.11 7.11 0 1 1 5.57 2.89Zm3.9-5.32c-.21-.11-1.27-.63-1.47-.7-.2-.07-.34-.11-.49.11-.14.21-.56.7-.69.84-.13.14-.25.16-.46.05-.21-.11-.9-.33-1.72-1.06-.64-.57-1.07-1.27-1.2-1.49-.13-.21-.01-.33.1-.44.1-.1.21-.25.32-.38.11-.13.14-.21.21-.36.07-.14.04-.27-.02-.38-.05-.11-.49-1.18-.67-1.62-.18-.43-.36-.37-.49-.38h-.42c-.14 0-.38.05-.58.27-.2.21-.76.74-.76 1.81s.78 2.1.89 2.25c.11.14 1.53 2.34 3.71 3.28.52.22.92.36 1.23.46.52.17.99.14 1.36.09.41-.06 1.27-.52 1.45-1.02.18-.5.18-.94.13-1.02-.05-.09-.2-.14-.41-.25Z" />
            </svg>
            WhatsApp
          </a>
        </div>

        <div class="hero-socials" aria-label="Redes sociales">
          <span>Redes</span>
          <a href={instagramUrl} target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2" />
              <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2" />
              <circle cx="17.5" cy="6.5" r="1.25" fill="currentColor" />
            </svg>
            Instagram
          </a>
        </div>
      </div>

      <dl class="mt-10 grid max-w-xl grid-cols-3 gap-3 text-sm">
        <div class="rounded-3xl bg-white/70 p-4 shadow-card ring-1 ring-white/70 backdrop-blur"><dt class="font-display text-xl text-horno-magenta">Loja</dt><dd class="mt-1 text-horno-magentaDeep/65">entregas</dd></div>
        <div class="rounded-3xl bg-white/70 p-4 shadow-card ring-1 ring-white/70 backdrop-blur"><dt class="font-display text-xl text-horno-magenta">48h</dt><dd class="mt-1 text-horno-magentaDeep/65">ideal</dd></div>
        <div class="rounded-3xl bg-white/70 p-4 shadow-card ring-1 ring-white/70 backdrop-blur"><dt class="font-display text-xl text-horno-magenta">100%</dt><dd class="mt-1 text-horno-magentaDeep/65">artesanal</dd></div>
      </dl>
    </div>

    <div class="relative flex min-h-[360px] items-center justify-center lg:min-h-[500px]">
      <div class="hero-card" aria-hidden="true">
        <div class="hero-card-grid"></div>
        <div class="penguin-sprite" aria-hidden="true"></div>
        <div class="order-ticket order-ticket-top">Chef de marca</div>
        <div class="order-ticket order-ticket-bottom">Pedido guiado</div>
      </div>
    </div>
  </div>
</header>

<script>
  import "~/scripts/mobile-nav.js";
</script>

<div class="ornament-divider" aria-hidden="true"></div>
