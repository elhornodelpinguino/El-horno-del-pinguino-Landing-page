---
import { SITE, whatsappLink } from "~/lib/config";
---

<section id="como-pedir" class="order-section animate-on-scroll relative overflow-hidden py-20 sm:py-28">
  <div class="ios-bubble order-bubble order-bubble-1" aria-hidden="true"></div>
  <div class="ios-bubble order-bubble order-bubble-2" aria-hidden="true"></div>

  <div class="section relative z-10">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <span class="eyebrow rounded-full bg-white/70 px-4 py-2 shadow-card backdrop-blur">Pedido guiado</span>
      <h2 class="mt-4 text-3xl sm:text-4xl">
        Tres pasos, sin vueltas
      </h2>
    </div>

    <div class="animate-group mx-auto grid max-w-5xl gap-6 md:grid-cols-3">
      <article class="order-step-card animate-item" style="--i: 0">
        <div class="pixel-scene pixel-scene-generated" aria-hidden="true"><div class="penguin-action-sprite penguin-phone-action"></div></div>
        <span class="order-step-number">01</span>
        <h3>Escribís por WhatsApp</h3>
      </article>

      <article class="order-step-card animate-item order-step-card-featured" style="--i: 1">
        <div class="pixel-scene pixel-scene-generated" aria-hidden="true"><div class="penguin-action-sprite penguin-baking-action"></div></div>
        <span class="order-step-number">02</span>
        <h3>Se hornea tu pedido</h3>
      </article>

      <article class="order-step-card animate-item" style="--i: 2">
        <div class="pixel-scene pixel-scene-generated" aria-hidden="true"><div class="penguin-action-sprite penguin-delivery-action"></div></div>
        <span class="order-step-number">03</span>
        <h3>Coordinamos entrega</h3>
      </article>
    </div>

    <div class="mt-10 text-center">
      <a href={whatsappLink(`¡Hola ${SITE.name}! Quiero hacer un pedido.`)} target="_blank" rel="noopener" class="btn-primary">
        Empezar pedido
      </a>
    </div>
  </div>
</section>

<div class="ornament-divider" aria-hidden="true"></div>
