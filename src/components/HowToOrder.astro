---
import { SITE, whatsappLink } from "~/lib/config";

const steps = [
  { number: "01", title: "Contás la ocasión y cantidad", penguinClass: "penguin-step-1" },
  { number: "02", title: "Definimos sabor y presentación", penguinClass: "penguin-step-2" },
  { number: "03", title: "Coordinamos pago y entrega", penguinClass: "penguin-step-3" },
];
---

<section id="como-pedir" class="order-section relative overflow-hidden py-20 sm:py-28">
  <div class="section relative z-10">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <span data-order-anim="eyebrow" class="eyebrow">Pedido guiado</span>
      <h2 data-order-anim="heading" class="mt-2 text-3xl leading-tight sm:text-4xl">
        Tres pasos, cero vueltas
      </h2>
    </div>

    <div class="mx-auto grid max-w-5xl gap-6 md:grid-cols-3">
      {steps.map((step, index) => (
        <article data-order-anim="step" class="order-step-card" style={`--i: ${index}`}>
          <div data-order-anim="sprite" class:list={["penguin-step", step.penguinClass]} aria-hidden="true"></div>
          <span class="order-step-number">{step.number}</span>
          <h3>{step.title}</h3>
        </article>
      ))}
    </div>

    <div data-order-anim="cta" class="mt-10 text-center">
      <a href={whatsappLink(`¡Hola ${SITE.name}! Quiero cotizar postres para una empresa, colegio o cafetería.`)} target="_blank" rel="noopener" class="btn-primary">
        Cotizar pedido
      </a>
    </div>
  </div>
</section>

<script>
  import "~/scripts/order-animation.js";
</script>
