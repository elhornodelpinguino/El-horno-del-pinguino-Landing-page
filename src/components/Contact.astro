---
import { SITE, whatsappLink, instagramLink } from "~/lib/config";
---

<footer id="contacto" class="animate-on-scroll bg-horno-magentaDeep text-horno-cream">
  <div class="section py-12">
    <div class="grid gap-8 sm:grid-cols-3">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/isotipo.png" alt="Isotipo" class="h-10 w-10 object-contain brightness-0 invert" />
          <span class="font-display text-lg text-white">{SITE.name}</span>
        </div>
        <p class="text-sm text-horno-cream/70 max-w-xs leading-relaxed">
          Postres artesanales con buena presentación, sabor consistente y atención cercana.
        </p>
      </div>

      <div>
        <h4 class="font-display text-white text-sm uppercase tracking-widest mb-4">Contacto</h4>
        <ul class="space-y-3 text-sm text-horno-cream/70">
          <li>
            <a href={whatsappLink(`Hola ${SITE.name}!`)} target="_blank" rel="noopener" class="hover:text-white transition flex items-center gap-2">
              <svg viewBox="0 0 32 32" class="h-5 w-5" aria-hidden="true"><circle cx="16" cy="16" r="15" fill="#25D366"/><path fill="#fff" d="M16.04 7.15a8.64 8.64 0 0 0-7.38 13.12l-.93 3.43 3.51-.92a8.65 8.65 0 1 0 4.8-15.63Zm0 15.77a7.1 7.1 0 0 1-3.62-.99l-.26-.15-2.08.54.56-2.02-.17-.27a7.11 7.11 0 1 1 5.57 2.89Zm3.9-5.32c-.21-.11-1.27-.63-1.47-.7-.2-.07-.34-.11-.49.11-.14.21-.56.7-.69.84-.13.14-.25.16-.46.05-.21-.11-.9-.33-1.72-1.06-.64-.57-1.07-1.27-1.2-1.49-.13-.21-.01-.33.1-.44.1-.1.21-.25.32-.38.11-.13.14-.21.21-.36.07-.14.04-.27-.02-.38-.05-.11-.49-1.18-.67-1.62-.18-.43-.36-.37-.49-.38h-.42c-.14 0-.38.05-.58.27-.2.21-.76.74-.76 1.81s.78 2.1.89 2.25c.11.14 1.53 2.34 3.71 3.28.52.22.92.36 1.23.46.52.17.99.14 1.36.09.41-.06 1.27-.52 1.45-1.02.18-.5.18-.94.13-1.02-.05-.09-.2-.14-.41-.25Z"/></svg>
              +{SITE.whatsapp}
            </a>
          </li>
          <li>
            <a href={instagramLink()} target="_blank" rel="noopener" class="hover:text-white transition flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.25" fill="currentColor"/></svg>
              @{SITE.instagram}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-display text-white text-sm uppercase tracking-widest mb-4">Dirección</h4>
        <p class="text-sm text-horno-cream/70 leading-relaxed">
          {SITE.location}<br />
          Entregas en Loja
        </p>
      </div>
    </div>

    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-horno-cream/50">
      <p>© {new Date().getFullYear()} {SITE.name} · Hecho con 🐧 en Loja, Ecuador</p>
    </div>
  </div>
</footer>
