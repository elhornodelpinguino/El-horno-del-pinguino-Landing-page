---
import { SITE, whatsappLink, instagramLink, tiktokLink } from "~/lib/config";

const socials = [
  {
    name: "Instagram",
    href: instagramLink(),
    icon: "instagram",
  },
  {
    name: "WhatsApp",
    href: whatsappLink(`Hola ${SITE.name}! Vengo desde su web.`),
    icon: "whatsapp",
  },
  {
    name: "TikTok",
    href: tiktokLink(),
    icon: "tiktok",
  },
];
---

<footer id="contacto" class="bg-horno-magentaDeep text-horno-cream">
  <div class="section py-12">
    <div class="grid gap-8 sm:grid-cols-3">
      <div data-contact-anim="column">
        <img src="/logo-horizontal.svg" alt="El Horno del Pingüino" class="mb-4 h-10 w-auto object-contain brightness-0 invert" />
        <p class="text-sm text-horno-cream/70 max-w-xs leading-relaxed">
          Postres artesanales para empresas, colegios y cafeterías en Loja.
        </p>
      </div>

      <div data-contact-anim="column">
        <h4 class="font-display text-white text-sm uppercase tracking-widest mb-4">Contacto</h4>
        <ul class="space-y-3 text-sm text-horno-cream/70">
          <li>
            <a href={whatsappLink(`Hola ${SITE.name}!`)} target="_blank" rel="noopener" class="hover:text-white transition flex items-center gap-2">
              <svg viewBox="0 0 32 32" class="h-5 w-5" aria-hidden="true"><circle cx="16" cy="16" r="15" fill="#25D366"/><path fill="#fff" d="M16.04 7.15a8.64 8.64 0 0 0-7.38 13.12l-.93 3.43 3.51-.92a8.65 8.65 0 1 0 4.8-15.63Zm0 15.77a7.1 7.1 0 0 1-3.62-.99l-.26-.15-2.08.54.56-2.02-.17-.27a7.11 7.11 0 1 1 5.57 2.89Zm3.9-5.32c-.21-.11-1.27-.63-1.47-.7-.2-.07-.34-.11-.49.11-.14.21-.56.7-.69.84-.13.14-.25.16-.46.05-.21-.11-.9-.33-1.72-1.06-.64-.57-1.07-1.27-1.2-1.49-.13-.21-.01-.33.1-.44.1-.1.21-.25.32-.38.11-.13.14-.21.21-.36.07-.14.04-.27-.02-.38-.05-.11-.49-1.18-.67-1.62-.18-.43-.36-.37-.49-.38h-.42c-.14 0-.38.05-.58.27-.2.21-.76.74-.76 1.81s.78 2.1.89 2.25c.11.14 1.53 2.34 3.71 3.28.52.22.92.36 1.23.46.52.17.99.14 1.36.09.41-.06 1.27-.52 1.45-1.02.18-.5.18-.94.13-1.02-.05-.09-.2-.14-.41-.25Z"/></svg>
              +{SITE.whatsapp}
            </a>
          </li>
          <li>
            <a href={instagramLink()} target="_blank" rel="noopener" class="hover:text-white transition flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.25" fill="currentColor"/></svg>
              @{SITE.instagram}
            </a>
          </li>
        </ul>
      </div>

      <div data-contact-anim="column">
        <h4 class="font-display text-white text-sm uppercase tracking-widest mb-4">Dirección</h4>
        <p class="text-sm text-horno-cream/70 leading-relaxed">
          {SITE.location}<br />
          Entregas en Loja
        </p>
      </div>
    </div>

    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-5 text-sm text-horno-cream/50" data-contact-anim="bar">
      <p>© {new Date().getFullYear()} {SITE.name} · Hecho en Loja, Ecuador</p>

      <div class="flex items-center gap-4">
        <span class="font-display text-xs uppercase tracking-widest text-horno-cream/60">Síguenos</span>
        <ul class="flex items-center gap-3">
          {socials.map((social) => (
            <li>
              <a
                href={social.href}
                target="_blank"
                rel="noopener"
                aria-label={`${social.name} de ${SITE.name}`}
                class="flex h-11 w-11 items-center justify-center rounded-full border border-white/15 bg-white/10 text-horno-cream transition duration-300 hover:-translate-y-0.5 hover:bg-white/20 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/60"
              >
                {social.icon === "instagram" && (
                  <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.25" fill="currentColor"/></svg>
                )}
                {social.icon === "whatsapp" && (
                  <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true"><path d="M12.04 2a9.9 9.9 0 0 0-8.46 15.04L2.2 21.8l4.87-1.28A9.9 9.9 0 1 0 12.04 2Zm0 18.06a8.13 8.13 0 0 1-4.14-1.13l-.3-.18-2.89.76.77-2.81-.2-.3a8.16 8.16 0 1 1 6.76 3.66Zm4.47-6.1c-.24-.12-1.45-.72-1.68-.8-.22-.08-.39-.12-.55.13-.17.24-.64.8-.79.96-.14.16-.29.18-.53.06-.24-.12-1.03-.38-1.97-1.21-.73-.65-1.22-1.46-1.36-1.7-.15-.25-.02-.38.1-.5.11-.11.25-.29.37-.44.12-.15.16-.25.24-.41.08-.16.04-.3-.02-.43-.06-.12-.55-1.35-.76-1.85-.2-.49-.41-.42-.56-.43h-.48c-.16 0-.43.06-.66.3-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.57.12.16 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.47-.07 1.45-.6 1.65-1.17.2-.57.2-1.07.14-1.17-.06-.1-.22-.16-.46-.28Z"/></svg>
                )}
                {social.icon === "tiktok" && (
                  <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64c.28 0 .57.05.88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.04-.1Z"/></svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</footer>

<script>
  import "~/scripts/contact-animation.js";
</script>
