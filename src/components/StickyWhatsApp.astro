---
import { SITE, whatsappLink } from "~/lib/config";

const message = `¡Hola ${SITE.name}! Vi su web y quiero hacer un pedido.`;
---

<a
  href={whatsappLink(message)}
  target="_blank"
  rel="noopener"
  class="sticky-whatsapp md:hidden"
  aria-label="Hacer pedido por WhatsApp"
>
  <span class="sticky-whatsapp-icon" aria-hidden="true">
    <svg viewBox="0 0 32 32" fill="currentColor" class="h-6 w-6">
      <path d="M16.02 3.2A12.72 12.72 0 0 0 5.1 22.45L3.6 28.8l6.49-1.48A12.7 12.7 0 1 0 16.02 3.2Zm0 22.18c-1.98 0-3.82-.6-5.35-1.63l-.38-.25-3.84.88.9-3.76-.25-.39a9.47 9.47 0 1 1 8.92 5.15Zm5.46-7.07c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.49s1.07 2.89 1.22 3.09c.15.2 2.11 3.22 5.1 4.51.71.31 1.27.49 1.71.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.13-.27-.2-.57-.35Z" />
    </svg>
  </span>
  <span>
    <span class="block text-[11px] font-medium leading-none text-white/80">Pedido rápido</span>
    <span class="block font-display text-sm leading-tight">WhatsApp</span>
  </span>
</a>
