---
import { SITE, whatsappLink } from "~/lib/config";

const orderLink = whatsappLink(`¡Hola ${SITE.name}! Quiero cotizar postres para una empresa, colegio o cafetería. ¿Me ayudan con opciones y cantidades?`);
---

<section class="final-cta relative overflow-hidden bg-horno-gradient-strong py-20 sm:py-28">
  <div class="section relative z-10 flex flex-col items-center text-center">
    <span data-finalcta-anim="label" class="inline-flex items-center gap-2 rounded-full border border-white/18 bg-white/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-white/90">
      Cotización directa
    </span>
    <h2 data-finalcta-anim="heading" class="mt-5 max-w-3xl text-3xl leading-tight text-white sm:text-5xl">
      Convertí tu reunión, evento o vitrina en un pedido claro y presentable.
    </h2>
    <p data-finalcta-anim="copy" class="mt-5 max-w-xl text-base leading-relaxed text-white/90 sm:text-lg">
      Escríbenos por WhatsApp con fecha, cantidad y ocasión, y te guiamos con el resto.
    </p>

    <div data-finalcta-anim="actions" class="mt-8">
      <a
        href={orderLink}
        target="_blank"
        rel="noopener"
        data-magnetic
        class="inline-flex items-center gap-3 rounded-full bg-white px-7 py-4 font-display font-semibold text-horno-magenta shadow-soft transition-all duration-300 hover:-translate-y-0.5 hover:bg-horno-cream"
      >
        <svg viewBox="0 0 32 32" class="h-7 w-7" aria-hidden="true">
          <circle cx="16" cy="16" r="15" fill="#25D366" />
          <path fill="#fff" d="M16.04 7.15a8.64 8.64 0 0 0-7.38 13.12l-.93 3.43 3.51-.92a8.65 8.65 0 1 0 4.8-15.63Zm0 15.77a7.1 7.1 0 0 1-3.62-.99l-.26-.15-2.08.54.56-2.02-.17-.27a7.11 7.11 0 1 1 5.57 2.89Zm3.9-5.32c-.21-.11-1.27-.63-1.47-.7-.2-.07-.34-.11-.49.11-.14.21-.56.7-.69.84-.13.14-.25.16-.46.05-.21-.11-.9-.33-1.72-1.06-.64-.57-1.07-1.27-1.2-1.49-.13-.21-.01-.33.1-.44.1-.1.21-.25.32-.38.11-.13.14-.21.21-.36.07-.14.04-.27-.02-.38-.05-.11-.49-1.18-.67-1.62-.18-.43-.36-.37-.49-.38h-.42c-.14 0-.38.05-.58.27-.2.21-.76.74-.76 1.81s.78 2.1.89 2.25c.11.14 1.53 2.34 3.71 3.28.52.22.92.36 1.23.46.52.17.99.14 1.36.09.41-.06 1.27-.52 1.45-1.02.18-.5.18-.94.13-1.02-.05-.09-.2-.14-.41-.25Z" />
        </svg>
        Cotizar por WhatsApp
      </a>
    </div>
  </div>
</section>

<script>
  import "~/scripts/final-cta-animation.js";
</script>
