---
import ProductCard from "./ProductCard.astro";
import type { Product } from "~/lib/api";

interface Props {
  products: Product[];
}

const { products } = Astro.props;
---

<section id="catalogo" class="py-20 sm:py-28">
  <div class="section">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="eyebrow">Nuestro catálogo</span>
      <h2 class="text-3xl sm:text-4xl mb-4">
        Dulces que <span class="text-horno-magenta">encantan</span>
      </h2>
      <p class="text-horno-magentaDeep/70">
        Cada postre es una obra de arte hecha a mano con ingredientes seleccionados y
        mucho cariño. Descubre nuestras creaciones disponibles.
      </p>
    </div>

    {
      products.length === 0 ? (
        <div class="text-center py-20 bg-white/60 rounded-3xl shadow-card">
          <p class="text-4xl mb-3">🍰</p>
          <p class="font-display text-xl text-horno-magentaDeep">Estamos preparando nuevas creaciones</p>
          <p class="text-horno-magentaDeep/60 mt-2">Vuelve pronto o escríbenos por WhatsApp para encargos personalizados.</p>
        </div>
      ) : (
        <div class="grid gap-6 sm:gap-7 sm:grid-cols-2 lg:grid-cols-3">
          {products.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      )
    }
  </div>
</section>

<div class="ornament-divider" aria-hidden="true"></div>
