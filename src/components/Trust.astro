---
const stats = [
  { value: 120, prefix: "+", suffix: "", caption: "pedidos entregados" },
  { value: 5, prefix: "", suffix: " años", caption: "horneando en Loja" },
  { value: 100, prefix: "", suffix: "%", caption: "artesanal, sin atajos" },
];
---

<section class="trust-section relative overflow-hidden py-20 sm:py-28" aria-label="Resultados de la pastelería">
  <div class="section relative z-10 grid items-center gap-12 lg:grid-cols-[auto_1fr]">
    <div data-trust-anim="penguin" class="penguin-trust mx-auto lg:mx-0" aria-hidden="true"></div>

    <div class="grid gap-10 text-center sm:grid-cols-3 sm:text-left">
      {stats.map((stat) => (
        <div data-trust-anim="stat">
          <p class="font-display text-5xl font-bold leading-none text-horno-orange sm:text-6xl">
            {stat.prefix}<span data-trust-count data-count-to={stat.value}>{stat.value}</span>{stat.suffix}
          </p>
          <p class="mt-3 text-sm uppercase tracking-[0.18em] text-horno-cream/80">{stat.caption}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import "~/scripts/trust-animation.js";
</script>
