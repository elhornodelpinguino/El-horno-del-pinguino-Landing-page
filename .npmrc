legacy-peer-deps=true

# Security: fail install if Node version doesn't match engines field
engine-strict=true

# Security: save exact versions (no ^ or ~) when adding deps
save-exact=true

# Security: block lifecycle scripts (postinstall, preinstall) on install
# Scripts run manually or in CI after review
ignore-scripts=true

# Security: verify integrity of downloaded packages
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
